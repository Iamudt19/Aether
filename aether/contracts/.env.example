# ============================================
# Aether Contracts — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Polygon Amoy RPC URL (from Alchemy or Infura)
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployer wallet private key (throwaway wallet only!)
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# The PUBLIC ADDRESS of the AI signer wallet (from backend)
# This is the address derived from BACKEND AI_SIGNER_PRIVATE_KEY
AI_SIGNER_ADDRESS=0xYOUR_AI_SIGNER_PUBLIC_ADDRESS

# Treasury wallet — receives 2.5% marketplace fees
TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET_ADDRESS

# Optional: Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
