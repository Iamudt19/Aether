# ============================================
# Aether Backend — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# AI Signer private key (throwaway wallet — NOT your main wallet!)
AI_SIGNER_PRIVATE_KEY=0xYOUR_AI_SIGNER_PRIVATE_KEY

# Pinata JWT for uploading NFT metadata to IPFS
PINATA_JWT=eyJhbGci...YOUR_PINATA_JWT

# Deployed contract address (from running deploy.js)
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Polygon Amoy RPC URL
RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Frontend URL for CORS (adjust if hosting frontend elsewhere)
FRONTEND_URL=http://localhost:3000

# Server port
PORT=3001
